datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("iam_users")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  rawContent  String?   @db.Text
  aiContent   String?   @db.Text
  imageUrl    String?
  galleryImageUrls String?   @db.Text
  wpPostId    Int?
  price       String?
  sku         String?
  material    String?
  carModels   String?
  shopeeLink  String?
  lazadaLink  String?
  tiktokLink  String?
  videoUrl    String?
  category    String?
  tags        String?   @db.Text

  status      JobStatus @default(PENDING)
  errorLog    String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("catalog_products")
}

model CategoryMapping {
  id             String   @id @default(uuid())
  excelValue     String   @unique
  wpCategoryId   Int
  wpCategoryName String
  updatedAt      DateTime @updatedAt

  @@map("catalog_category_mappings")
}

model ApiLog {
  id             String   @id @default(uuid())
  method         String
  endpoint       String
  requestHeader  String?  @db.Text
  requestBody    String?  @db.Text
  responseBody   String?  @db.Text
  statusCode     Int
  duration       Int      // in ms
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())

  @@map("system_api_logs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}