generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("iam_users")
}

model Product {
  id               String    @id @default(uuid())
  name             String
  description      String?
  rawContent       String?
  aiContent        String?
  imageUrl         String?
  galleryImageUrls String?
  wpPostId         Int?
  price            String?
  sku              String?
  material         String?
  carModels        String?
  shopeeLink       String?
  lazadaLink       String?
  tiktokLink       String?
  videoUrl         String?
  category         String?
  status           JobStatus @default(PENDING)
  errorLog         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tags             String?
  deletedAt        DateTime?

  @@map("catalog_products")
}

model CategoryMapping {
  id             String   @id @default(uuid())
  excelValue     String   @unique
  wpCategoryId   String
  wpCategoryName String
  updatedAt      DateTime @updatedAt

  @@map("catalog_category_mappings")
}

model ApiLog {
  id            String   @id @default(uuid())
  method        String
  endpoint      String
  requestHeader String?
  requestBody   String?
  responseBody  String?
  statusCode    Int
  duration      Int
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@map("system_api_logs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
