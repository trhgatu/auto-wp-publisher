generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("iam_users")
}

model Product {
  id               String    @id @default(uuid())
  name             String
  description      String?
  shortDescription String?
  rawContent       String?
  aiContent        String?
  imageUrl         String?
  galleryImageUrls String?
  wpPostId         Int?
  wpUrl            String?
  price            String?
  sku              String?
  material         String?
  carModels        String?
  shopeeLink       String?
  lazadaLink       String?
  tiktokLink       String?
  videoUrl         String?
  category         String?
  brand            String?
  status           JobStatus @default(PENDING)
  errorLog         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tags             String?
  deletedAt        DateTime?

  @@map("catalog_products")
}

model CategoryMapping {
  id             String   @id @default(uuid())
  excelValue     String   @unique
  wpCategoryId   String
  wpCategoryName String
  updatedAt      DateTime @updatedAt

  @@map("catalog_category_mappings")
}

model BrandMapping {
  id          String   @id @default(uuid())
  excelValue  String   @unique
  wpBrandId   String
  wpBrandName String
  updatedAt   DateTime @updatedAt

  @@map("catalog_brand_mappings")
}

model ApiLog {
  id            String   @id @default(uuid())
  method        String
  endpoint      String
  requestHeader String?
  requestBody   String?
  responseBody  String?
  statusCode    Int
  duration      Int
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@map("system_api_logs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AiSetting {
  id           String   @id @default("default")
  systemPrompt String
  temperature  Float    @default(0.7)
  modelName    String   @default("gemini-2.5-flash")
  updatedAt    DateTime @updatedAt

  @@map("catalog_ai_settings")
}
