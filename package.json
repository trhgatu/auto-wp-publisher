{
    "name": "auto-wp-publisher",
    "private": true,
    "scripts": {
        "dev": "dotenv -e .env -- turbo run dev",
        "build": "dotenv -e .env -- turbo run build",
        "db:generate": "pnpm -F @repo/database db:generate",
        "db:push": "pnpm -F @repo/database db:push",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types",
        "prepare": "husky"
    },
    "lint-staged": {
        "apps/server/src/**/*.ts": [
            "pnpm -F @repo/server lint",
            "pnpm -F @repo/server format"
        ],
        "apps/web/src/**/*.{ts,tsx}": [
            "pnpm -F @repo/web lint",
            "prettier --write"
        ],
        "packages/**/*.{ts,tsx}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "dotenv-cli": "^11.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.7.4",
        "turbo": "^2.8.17",
        "typescript": "5.9.2"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    }
}
